OPENAI_API_KEY=your_api_key_here
PICOVOICE_ACCESS_KEY=your_picovoice_access_key_here
ASSISTANT_WAKE_WORD=porcupine
ASSISTANT_PORCUPINE_KEYWORD=porcupine
ASSISTANT_PORCUPINE_KEYWORD_PATH=
ASSISTANT_CHAT_MODEL=gpt-4o-mini
ASSISTANT_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
ASSISTANT_TRANSCRIPTION_FALLBACK_MODELS=gpt-4o-transcribe,whisper-1
ASSISTANT_SYSTEM_PROMPT=You are a concise desktop voice assistant for a PC. Answer clearly and briefly.
ASSISTANT_LISTEN_TIMEOUT=5
ASSISTANT_PHRASE_TIME_LIMIT=10
ASSISTANT_FOLLOW_UP_ENABLED=true
ASSISTANT_FOLLOW_UP_TURN_LIMIT=2
ASSISTANT_FOLLOW_UP_TIMEOUT=8
ASSISTANT_SAFE_TOOL_MODE=true
ASSISTANT_IDLE_TIMEOUT_SECONDS=900
ASSISTANT_MEMORY_ENABLED=true
ASSISTANT_MEMORY_TURN_LIMIT=6
ASSISTANT_MEMORY_FACT_LIMIT=24
ASSISTANT_TTS_ENABLED=true
ASSISTANT_TTS_MODEL=gpt-4o-mini-tts
ASSISTANT_TTS_FALLBACK_MODELS=tts-1,tts-1-hd
ASSISTANT_TTS_VOICE=alloy
ASSISTANT_TTS_SPEED=1.0
ASSISTANT_TTS_INSTRUCTIONS=
ASSISTANT_AMBIENT_ADJUST_SECONDS=1
ASSISTANT_AUDIO_DEVICE_INDEX=
ASSISTANT_EXIT_WORDS=quit assistant,exit assistant,stop listening
